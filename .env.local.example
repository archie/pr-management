# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers
# Authorization callback URL must be:
#   http://localhost:3000/api/auth/callback/github  (dev)
#   https://your-app.vercel.app/api/auth/callback/github  (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Set to https://your-app.vercel.app in production (Vercel auto-sets this).
# Leave unset for local dev (defaults to http://localhost:3000).
# AUTH_URL=
